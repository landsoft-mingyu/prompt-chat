# ──────────────────────────────────────────────────────
# prompt_chat 환경변수 예시
# 실제 운영 값은 .env 파일에 별도 관리 (Git 미포함)
# ──────────────────────────────────────────────────────

# ── 로컬 CUBRID (개발 전용, --profile dev 사용 시) ──────
CUBRID_HOST=cubrid
CUBRID_PORT=33000
CUBRID_DB=royal
CUBRID_USER=royal
CUBRID_PASSWORD=change-me

# ── ROYAL 시스템 DB (예약 프록시용 직접 연결) ────────────
ROYAL_HOST=192.168.12.55
ROYAL_PORT=33000
ROYAL_DB=royal
ROYAL_USER=royal
ROYAL_PASSWORD=change-me

# ── ROYAL 시스템 HTTP API ───────────────────────────────
ROYAL_API_BASE_URL=https://royal.landsoft.co.kr/ROYAL/api/v1/res
ROYAL_API_TIMEOUT_SEC=30

# ── LLM (외부 vLLM 서버 — compose 내 컨테이너 없음) ──────
LLM_BASE_URL=http://192.168.12.57:18081/v1
LLM_MODEL=gemma-3-12b
LLM_API_KEY=change-me
LLM_TIMEOUT_SEC=30

# ── RAG — Milvus ────────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=chunks

# ── RAG — 임베딩 서비스 ─────────────────────────────────
EMBEDDING_URL=http://embedding:8000

# ── Redis ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (Milvus 백엔드 — 변경 시 compose와 동기화 필요) ─
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── CORS ────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=["http://192.168.12.57:3005"]
